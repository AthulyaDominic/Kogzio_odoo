<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- TREE/List VIEW -->

    <record id="view_rental_vehicle_tree" model="ir.ui.view">
        <field name="name">rental.vehicle.tree</field>
        <field name="model">rental.vehicle</field>
        <field name="arch" type="xml">
          <list sample="1" string="Vehicles">
            <field name="vehicle_id"/>
            <field name="name"/>
            <field name="brand"/>
              <field name="model_year"/>


            <field name="status" widget="badge"
            decoration-success="status == 'available'"
            decoration-warning="status == 'rented'"
            decoration-muted="status == 'sold'"
            />


          </list>
        </field>
    </record>


    <!-- FORM VIEW -->
    <record id="view_rental_vehicle_form" model="ir.ui.view">
        <field name="name">rental.vehicle.form</field>
        <field name="model">rental.vehicle</field>
        <field name="arch" type="xml">
          <form>
              <header>






                     <field name="status"
                      widget="statusbar"
                      statusbar_visible="available,rented,sold"
                      options="{'clickable':1}"/>

              </header>
             <sheet>
                  <div class="oe_button_box" name="button_box">

                         <button name="action_rental_history"
                          type="object"
                          class="oe_stat_button"
                           icon="fa-history"
                           string="Rental History"/>

                  </div>
                 <field name="image_1920"
                   widget="image"
                   class="oe_avatar"/>
                 <group>
                     <field name="vehicle_id"/>
                     <field name="name"/>
                     <field name="brand"/>
                     <field name="registration_date"/>
                     <field name="model_year"/>
                     <field name="price"/>

                     <field name="feature_ids" widget="many2many_tags"/>
                 </group>
             </sheet>
              <chatter/>
          </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_rental_vehicle"
        model="ir.actions.act_window">

    <field name="name">Vehicles</field>

    <field name="res_model">rental.vehicle</field>

    <field name="view_mode">list,form</field>





    <field name="search_view_id"
           ref="vehicle_rental_search_view"/>

    <field name="context">
        {'search_default_available':1}
    </field>

        <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Create your first vehicle
        </p>
        <p>
            Manage vehicle rentals, availability and features.
        </p>
    </field>

 </record>
</odoo>