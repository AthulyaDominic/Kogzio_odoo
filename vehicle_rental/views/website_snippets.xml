<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="vehicle_top_snippet" inherit_id="website.snippets">
       <xpath expr="//snippets[@id='snippet_content']"
               position="inside">
           <!--snippet registration will go here-->
            <t t-snippet="vehicle_rental.template_top_vehicle"
               string="Top Rental Vehicles"
               t-thumbnail="/website/static/src/img/snippets_thumbs/s_text_image.svg"/>

        </xpath>
    </template>
</odoo>