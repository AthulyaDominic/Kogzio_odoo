<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="vehicle_rental_form_template" name="Vehicle Rental Form">
        <div class="container mt-5">
          <t t-call="website.layout">
            <h2>Vehicle Rental Request</h2>
              <form action="/vehicle/rental/submit" method="post">
                  <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                  <div class="mb-3">
                      <label>Name</label>
                      <input type="text" name="customer_name" class="form_control" required="required"/>
                  </div>
                  <div class="mb-3">
                      <label>Vehicle</label>

                        <select name="vehicle_id" class="form-control">
                             <t t-foreach="vehicles" t-as="vehicle">

                              <option t-att-value="vehicle.id">
                                  <t t-esc="vehicle.name"/>
                              </option>
                             </t>

                        </select>


                  </div>
              </form>
          </t>
        </div>
    </template>
</odoo>