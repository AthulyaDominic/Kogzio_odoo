<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="action_rental_request_report" model="ir.actions.report">
        <field name="name">Rental Request Report</field>
        <field name="model">rental.request</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">vehicle_rental.report_rental_request_template</field>
        <field name="report_file">vehicle_rental.report_rental_request_template</field>
        <field name="binding_model_id" ref="model_rental_request"/>
        <field name="binding_type">report</field>
    </record>


    <!--Qweb template creation-->
   <template id="report_rental_request_template">
     <t t-call="web.html_container">
         <t t-call="web.external_layout">
             <div class="page">
                 <h2>Rental Request Report</h2>
                 <table class="table table-bordered">
                     <thead>
                         <tr>
                             <th>Rental ID</th>
                             <th>Customer</th>
                             <th>Request Date</th>
                             <th>Rent Date</th>
                             <th>Return Date</th>
                             <th>Rental Period</th>
                             <th>Status</th>
                         </tr>
                         <tbody>
                             <t t-foreach="rows" t-as="row">
                                 <tr>
                                     <td>
                                         <t t-esc="row['rental_id']"/>
                                     </td>
                                     <td>
                                         <t t-esc="row['customer_name']"/>
                                     </td>
                                     <td>
                                         <t t-esc="row['request_date']"/>
                                     </td>
                                     <td>
                                         <t t-esc="row['rent_date']"/>
                                     </td>
                                     <td>
                                         <t t-esc="row['return_date']"/>
                                     </td>
                                     <td>
                                         <t t-esc="row['period']"/>
                                     </td>
                                     <td>
                                         <t t-esc="row['status']"/>
                                     </td>
                                 </tr>
                             </t>
                         </tbody>

                     </thead>
                 </table>
             </div>
         </t>





     </t>
  </template>
</odoo>